{
  "name": "pi-goblins",
  "version": "0.6.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "description": "Lightweight goblin orchestration for pi.",
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-goblins.git"
  },
  "homepage": "https://github.com/Jomik/pi-goblins",
  "keywords": [
    "pi",
    "agent",
    "subagent",
    "goblin",
    "orchestration",
    "llm"
  ],
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "prepublishOnly": "node -e \"console.error('npm publishing is disabled for this package'); process.exit(1)\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.81.1 <0.82.0",
    "@earendil-works/pi-coding-agent": ">=0.81.1 <0.82.0",
    "@earendil-works/pi-tui": ">=0.81.1 <0.82.0",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@earendil-works/pi-ai": "^0.81.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@earendil-works/pi-tui": "^0.81.1",
    "typebox": "^1.1.31",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
