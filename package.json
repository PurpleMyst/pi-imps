{
  "name": "pi-imps",
  "version": "0.3.0",
  "packageManager": "npm@11.12.1",
  "description": "Lightweight subagent orchestration for pi.",
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-imps.git"
  },
  "homepage": "https://github.com/Jomik/pi-imps",
  "keywords": [
    "pi",
    "agent",
    "subagent",
    "orchestration",
    "llm"
  ],
